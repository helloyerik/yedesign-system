{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@yerik/yedesign-system-tokens": ["packages/tokens/src/tokens.css"],
      "@yerik/yedesign-system-tokens/*": ["packages/tokens/src/*"],
      "@tokens/*": ["packages/tokens/src/*"],
      "@tokens-studio/*": ["packages/tokens/studio/*"],
      "@components/*": ["packages/components/src/*"],
      "@storybook-app/*": ["apps/storybook/src/*"]
    },
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": [
    "apps/storybook/.storybook/**/*.ts",
    "packages/**/*.ts",
    "packages/**/*.d.ts",
    "packages/**/*.vue",
    "apps/**/*.ts",
    "apps/**/*.d.ts",
    "apps/**/*.tsx",
    "apps/**/*.vue"
  ]
}
